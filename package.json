];

function PlayerCard({ player, index }: { player: Player; index: number }) {
  const ref    = useRef(null);
  const inView = useInView(ref, { once: true, margin: '-60px' });
  const Icon   = player.icon;

  return (
    <motion.div
      ref={ref}
      initial={{ opacity: 0, y: 60 }}
      animate={inView ? { opacity: 1, y: 0 } : {}}
      transition={{ duration: 0.65, delay: index * 0.1 }}
      className="group relative rounded-2xl overflow-hidden bg-dark-800 border border-brand-700/20 card-hover cursor-default"
    >
      {/* Player photo */}
      <div className="relative aspect-[3/4] overflow-hidden">
        <img
          src={player.image}
          alt={player.name}
          className="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
        />

        {/* Deep gradient overlay */}
        <div className="absolute inset-0 bg-gradient-to-t from-dark-900 via-dark-900/60 to-transparent" />

        {/* Purple sheen on hover */}
        <div className="absolute inset-0 bg-brand-600/15 opacity-0 group-hover:opacity-100 transition-opacity duration-400" />

        {/* Role badge — top right */}
        <div className="absolute top-3 right-3 z-10">
          <span className="font-orbitron font-black text-[10px] text-brand-200 tracking-widest px-2.5 py-1 rounded glass border border-brand-500/40">
            {player.badge}
          </span>
        </div>

        {/* Traits — top left, fade in */}
        <div className="absolute top-3 left-3 z-10 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-400">
          {player.traits.map((t) => (
            <div key={t} className="font-rajdhani text-[11px] text-brand-300 font-semibold uppercase leading-5">
              {t}
            </div>
          ))}
        </div>
      </div>

      {/* Card body */}
      <div className="p-5">
        {/* Icon + role */}
        <div className="flex items-center gap-2 mb-2">
          <Icon className="w-4 h-4 text-brand-400" />
          <span className="font-rajdhani text-brand-400 text-xs font-semibold uppercase tracking-widest">
            {player.role}
          </span>
        </div>

        {/* Name */}
        <h3 className="font-orbitron font-black text-2xl text-white mb-3 leading-tight">
          {player.name}
        </h3>

        {/* Divider */}
        <div className="h-px bg-gradient-to-r from-brand-600/40 via-brand-400/30 to-transparent mb-3" />

        {/* Quote — slides up on hover */}
        <p className="font-rajdhani text-sm text-brand-300/70 italic opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-400">
          "{player.quote}"
        </p>
      </div>

      {/* Bottom glow bar */}
      <div className="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-500/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400" />
    </motion.div>
  );
}

